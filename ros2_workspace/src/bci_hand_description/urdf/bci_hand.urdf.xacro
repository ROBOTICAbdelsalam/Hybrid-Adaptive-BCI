<?xml version="1.0"?>
<!--
  Five-finger robotic hand for the Hybrid Adaptive BCI.

  One revolute joint per finger (thumb, index, middle, ring, little), matching
  the FINGER_JOINTS defined in the robot abstraction layer. Each joint flexes
  from 0.0 rad (fully open) to 1.4 rad (fully closed). Geometry is primitive
  (boxes) so the model is self-contained - no mesh files or external packages.

  The controllers_config arg is injected by the launch file with the absolute
  path to hand_controllers.yaml, so the xacro needs no $(find) and expands
  standalone for verification.
-->
<robot name="bci_hand" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:arg name="controllers_config" default=""/>

  <!-- Finger flexion limits (radians) -->
  <xacro:property name="flex_min" value="0.0"/>
  <xacro:property name="flex_max" value="1.4"/>

  <material name="hand_grey">
    <color rgba="0.4 0.4 0.45 1.0"/>
  </material>
  <material name="finger_blue">
    <color rgba="0.2 0.4 0.8 1.0"/>
  </material>

  <!-- Reusable inertial for a small box link -->
  <xacro:macro name="box_inertial" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <inertia
        ixx="${(mass/12.0)*(y*y+z*z)}" ixy="0.0" ixz="0.0"
        iyy="${(mass/12.0)*(x*x+z*z)}" iyz="0.0"
        izz="${(mass/12.0)*(x*x+y*y)}"/>
    </inertial>
  </xacro:macro>

  <!-- One finger: link + revolute joint attached to the palm -->
  <xacro:macro name="finger" params="name px py">
    <link name="${name}_link">
      <visual>
        <origin xyz="0.035 0 0" rpy="0 0 0"/>
        <geometry><box size="0.070 0.016 0.016"/></geometry>
        <material name="finger_blue"/>
      </visual>
      <collision>
        <origin xyz="0.035 0 0" rpy="0 0 0"/>
        <geometry><box size="0.070 0.016 0.016"/></geometry>
      </collision>
      <xacro:box_inertial mass="0.02" x="0.070" y="0.016" z="0.016"/>
    </link>

    <joint name="${name}_joint" type="revolute">
      <parent link="palm"/>
      <child link="${name}_link"/>
      <origin xyz="${px} ${py} 0.0125" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${flex_min}" upper="${flex_max}" effort="10.0" velocity="2.0"/>
      <dynamics damping="0.1" friction="0.05"/>
    </joint>
  </xacro:macro>

  <!-- World anchor so the hand does not fall in simulation -->
  <link name="world"/>

  <link name="palm">
    <visual>
      <geometry><box size="0.090 0.100 0.025"/></geometry>
      <material name="hand_grey"/>
    </visual>
    <collision>
      <geometry><box size="0.090 0.100 0.025"/></geometry>
    </collision>
    <xacro:box_inertial mass="0.30" x="0.090" y="0.100" z="0.025"/>
  </link>

  <joint name="world_to_palm" type="fixed">
    <parent link="world"/>
    <child link="palm"/>
    <origin xyz="0 0 0.20" rpy="0 0 0"/>
  </joint>

  <!-- Four fingers along the front edge + an offset thumb -->
  <xacro:finger name="index"  px="0.045" py="0.030"/>
  <xacro:finger name="middle" px="0.045" py="0.010"/>
  <xacro:finger name="ring"   px="0.045" py="-0.010"/>
  <xacro:finger name="little" px="0.045" py="-0.030"/>
  <xacro:finger name="thumb"  px="0.010" py="0.050"/>

  <!-- ros2_control hardware description (Gazebo system) -->
  <ros2_control name="BCIHandSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <xacro:macro name="joint_ctrl" params="name">
      <joint name="${name}">
        <command_interface name="position">
          <param name="min">${flex_min}</param>
          <param name="max">${flex_max}</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
    </xacro:macro>
    <xacro:joint_ctrl name="thumb_joint"/>
    <xacro:joint_ctrl name="index_joint"/>
    <xacro:joint_ctrl name="middle_joint"/>
    <xacro:joint_ctrl name="ring_joint"/>
    <xacro:joint_ctrl name="little_joint"/>
  </ros2_control>

  <!-- Gazebo ros2_control plugin: loads the controller manager in-sim -->
  <gazebo>
    <plugin filename="gz_ros2_control-system"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(arg controllers_config)</parameters>
    </plugin>
  </gazebo>

</robot>
